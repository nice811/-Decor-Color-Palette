NODE_ENV=development
PORT=3001

# ============================================
# AI配色生成配置（Railway后台配置）
# ============================================
# AI服务地址（如OneAPI、NVIDIA、AI Proxy等）
AI_BASE_URL=https://api.openai.com/v1
# AI服务密钥（联系管理员获取）
AI_API_KEY=your-api-key-here
# AI模型名称
AI_MODEL=gpt-4o-mini
# 请求超时时间（毫秒）
AI_TIMEOUT=15000

# ============================================
# JWT认证配置
# ============================================
# JWT密钥（生产环境必须修改为复杂字符串）
JWT_SECRET=your-jwt-secret-key-here

# ============================================
# CORS跨域配置
# ============================================
# 允许访问的前端域名（生产环境填写实际域名）
ALLOW_ORIGIN=*
# 管理后台地址
ADMIN_FRONT_URL=http://localhost:3001
